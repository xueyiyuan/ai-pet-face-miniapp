.state {
  min-height: 60vh;
  color: #6f6257;
  font-size: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
}

.retry-btn {
  width: 320rpx;
}

.cover {
  width: 100%;
  height: 420rpx;
  margin-bottom: 24rpx;
  background: #f7efe5;
  border-radius: 16rpx;
}

.main-card,
.paid-card,
.locked-card {
  margin-bottom: 24rpx;
}

.title {
  color: #2f241d;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.25;
}

.label {
  display: inline-flex;
  margin-top: 20rpx;
  padding: 10rpx 20rpx;
  background: #eaf6f0;
  color: #247653;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.summary {
  margin-top: 24rpx;
  color: #5d5046;
  font-size: 30rpx;
  line-height: 1.7;
}

.section {
  margin-top: 30rpx;
}

.section-title {
  color: #3f3025;
  font-size: 28rpx;
  font-weight: 900;
}

.section-body,
.paid-item,
.locked-list,
.exclusive {
  margin-top: 12rpx;
  color: #5d5046;
  font-size: 28rpx;
  line-height: 1.72;
}

.paid-item {
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid rgba(82, 54, 31, 0.08);
}

.paid-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
  margin-top: 22rpx;
}

.paid-chip {
  padding: 18rpx 20rpx;
  color: #247653;
  background: #eaf6f0;
  border-radius: 12rpx;
  font-size: 26rpx;
  line-height: 1.45;
}

.exclusive {
  padding: 22rpx;
  background: #fff8ef;
  border-radius: 12rpx;
}

.locked-card .primary-btn {
  margin-top: 24rpx;
}

.share-btn {
  margin-top: 8rpx;
  color: #4c3a2d;
  background: #ffffff;
  border: 1rpx solid rgba(122, 88, 55, 0.16);
  border-radius: 16rpx;
  font-weight: 800;
}

.share-btn::after {
  border: 0;
}

.disclaimer {
  margin: 24rpx 0 20rpx;
  line-height: 1.55;
  text-align: center;
}
