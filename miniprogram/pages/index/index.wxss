.index-page {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.hero {
  width: 100%;
  padding: 64rpx 40rpx;
  box-sizing: border-box;
  background: #ffffff;
  border: 1rpx solid rgba(23, 32, 51, 0.08);
  border-radius: 16rpx;
  box-shadow: 0 16rpx 44rpx rgba(16, 30, 54, 0.08);
}

.brand {
  display: inline-flex;
  padding: 10rpx 18rpx;
  margin-bottom: 28rpx;
  background: #eaf6f0;
  color: #247653;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  color: #172033;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.18;
}

.subtitle {
  margin-top: 24rpx;
  color: #687386;
  font-size: 30rpx;
  line-height: 1.6;
}

.start-btn {
  margin-top: 44rpx;
}

.secondary-btn {
  width: 100%;
  height: 88rpx;
  margin-top: 20rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 88rpx;
}

.secondary-btn::after {
  border: 0;
}

.secondary-btn.green {
  color: #247653;
  background: #eaf6f0;
}

.secondary-btn.orange {
  color: #fb8c00;
  background: #fff3e0;
}

.notice {
  margin-top: 28rpx;
  color: #8a94a6;
  font-size: 24rpx;
  line-height: 1.55;
}
