.index-page {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.hero {
  width: 100%;
  padding: 72rpx 40rpx;
  box-sizing: border-box;
  background: #ffffff;
  border: 1rpx solid rgba(82, 54, 31, 0.08);
  border-radius: 16rpx;
  box-shadow: 0 16rpx 44rpx rgba(78, 47, 21, 0.08);
}

.brand {
  display: inline-flex;
  padding: 10rpx 18rpx;
  margin-bottom: 28rpx;
  background: #eaf6f0;
  color: #247653;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  max-width: 620rpx;
  color: #2f241d;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.18;
}

.subtitle {
  margin-top: 24rpx;
  color: #6f6257;
  font-size: 30rpx;
  line-height: 1.65;
}

.start-btn {
  margin-top: 48rpx;
}

.notice {
  margin-top: 28rpx;
  color: #8c7a69;
  font-size: 24rpx;
  line-height: 1.55;
}
