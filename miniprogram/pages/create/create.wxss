.page-title {
  margin-bottom: 24rpx;
  color: #2f241d;
  font-size: 42rpx;
  font-weight: 900;
}

.image-picker {
  width: 100%;
  height: 440rpx;
  margin: 0;
  padding: 0;
  overflow: hidden;
  background: #f7efe5;
  border: 2rpx dashed rgba(122, 88, 55, 0.28);
  border-radius: 16rpx;
  box-sizing: border-box;
}

.image-picker::after {
  border: 0;
}

.preview {
  width: 100%;
  height: 100%;
}

.placeholder {
  height: 100%;
  color: #8a7867;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.plus {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 10rpx;
  color: #fff;
  background: #ff8a3d;
  border-radius: 50%;
  font-size: 56rpx;
  line-height: 64rpx;
  text-align: center;
}

.field {
  margin: 32rpx 0;
}

.field-label {
  margin-bottom: 14rpx;
  color: #4c3a2d;
  font-size: 26rpx;
  font-weight: 800;
}

.prompt {
  width: 100%;
  min-height: 210rpx;
  padding: 22rpx 24rpx;
  background: #fff8ef;
  border: 1rpx solid rgba(122, 88, 55, 0.1);
  border-radius: 12rpx;
  box-sizing: border-box;
  color: #2f241d;
  font-size: 28rpx;
  line-height: 1.55;
}

.counter {
  margin-top: 10rpx;
  color: #8a7867;
  font-size: 22rpx;
  text-align: right;
}

.result-card {
  margin-top: 28rpx;
}

.result-title {
  margin-bottom: 18rpx;
  color: #2f241d;
  font-size: 32rpx;
  font-weight: 900;
}

.result-image {
  width: 100%;
  border-radius: 16rpx;
  background: #f7efe5;
}

.secondary-btn {
  width: 100%;
  height: 88rpx;
  margin-top: 22rpx;
  color: #247653;
  background: #eaf6f0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 88rpx;
}

.secondary-btn::after {
  border: 0;
}
