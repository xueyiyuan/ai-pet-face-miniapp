.room-page {
  min-height: 100vh;
  background: #f5f6f8;
}

.hero-img {
  width: 100%;
  height: 460rpx;
  display: block;
}

.content {
  padding: 24rpx;
}

.title-row {
  padding: 26rpx 0 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 800;
}

.address {
  margin-top: 12rpx;
  color: #687386;
  font-size: 25rpx;
  line-height: 1.42;
}

.price-card {
  margin-top: 18rpx;
  padding: 28rpx;
  display: flex;
  justify-content: space-between;
}

.label {
  color: #7d8798;
  font-size: 24rpx;
}

.price {
  margin-top: 10rpx;
  color: #e53935;
  font-size: 42rpx;
  font-weight: 800;
}

.value {
  margin-top: 14rpx;
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
}

.green {
  color: #18a058;
}

.info {
  padding: 8rpx 26rpx;
}

.info view {
  min-height: 76rpx;
  border-bottom: 2rpx solid #f0f2f5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 27rpx;
}

.info view:last-child {
  border-bottom: 0;
}

.info text {
  color: #7d8798;
}

.facility-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.facility-row view {
  height: 54rpx;
  padding: 0 22rpx;
  border-radius: 8rpx;
  background: #fff;
  color: #4b5567;
  font-size: 25rpx;
  display: flex;
  align-items: center;
}

.contact {
  padding: 0 26rpx;
}

.contact-row {
  min-height: 112rpx;
  border-bottom: 2rpx solid #f0f2f5;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.contact-row:last-child {
  border-bottom: 0;
}

.contact-name {
  font-size: 28rpx;
  font-weight: 700;
}

.contact-phone {
  margin-top: 8rpx;
  color: #7d8798;
  font-size: 24rpx;
}

.contact button {
  width: 108rpx;
  height: 58rpx;
  border-radius: 8rpx;
  background: #eef7f2;
  color: #18a058;
  font-size: 25rpx;
  line-height: 58rpx;
}

.notes {
  margin-top: 24rpx;
  padding: 24rpx;
  color: #4b5567;
  font-size: 26rpx;
  line-height: 1.6;
}

.action {
  margin: 28rpx 0 48rpx;
}
