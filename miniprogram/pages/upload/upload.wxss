.page-title {
  margin-bottom: 24rpx;
  color: #2f241d;
  font-size: 42rpx;
  font-weight: 900;
}

.image-picker {
  width: 100%;
  height: 460rpx;
  margin: 0;
  padding: 0;
  overflow: hidden;
  background: #f7efe5;
  border: 2rpx dashed rgba(122, 88, 55, 0.28);
  border-radius: 16rpx;
  box-sizing: border-box;
}

.image-picker::after {
  border: 0;
}

.preview {
  width: 100%;
  height: 100%;
}

.placeholder {
  height: 100%;
  color: #8a7867;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.plus {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 10rpx;
  color: #fff;
  background: #ff8a3d;
  border-radius: 50%;
  font-size: 56rpx;
  line-height: 64rpx;
}

.field {
  margin: 32rpx 0;
}

.field-label {
  margin-bottom: 14rpx;
  color: #4c3a2d;
  font-size: 26rpx;
  font-weight: 800;
}

.input {
  height: 88rpx;
  padding: 0 24rpx;
  background: #fff8ef;
  border: 1rpx solid rgba(122, 88, 55, 0.1);
  border-radius: 12rpx;
  box-sizing: border-box;
  font-size: 30rpx;
}

.type-switch {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.type-option {
  height: 76rpx;
  border: 1rpx solid rgba(122, 88, 55, 0.14);
  border-radius: 12rpx;
  color: #6d5e51;
  background: #fffaf4;
  font-size: 28rpx;
  line-height: 76rpx;
  text-align: center;
}

.type-option.active {
  border-color: #247653;
  color: #247653;
  background: #eaf6f0;
  font-weight: 800;
}

.note {
  margin-top: 24rpx;
  line-height: 1.55;
}
