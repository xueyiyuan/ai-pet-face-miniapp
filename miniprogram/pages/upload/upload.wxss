.title {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 32rpx;
}

.preview {
  width: 100%;
  height: 480rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  background: #f2e6d9;
}

.path {
  margin: 16rpx 0 8rpx;
  font-size: 24rpx;
  color: #a16a35;
  word-break: break-all;
}

.input {
  margin: 24rpx 0;
  padding: 24rpx;
  background: #fff8ef;
  border-radius: 18rpx;
}
