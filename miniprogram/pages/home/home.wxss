.home-page {
  padding-top: 0;
}

.top-band {
  margin: 0 -24rpx;
  padding: 36rpx 28rpx 42rpx;
  background: #fb8c00;
  color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.hello {
  font-size: 28rpx;
  opacity: 0.9;
}

.headline {
  width: 560rpx;
  margin-top: 12rpx;
  font-size: 42rpx;
  line-height: 1.28;
  font-weight: 800;
}

.add-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.24);
  color: #fff;
  font-size: 48rpx;
  line-height: 68rpx;
}

.search-row {
  height: 76rpx;
  margin-top: -24rpx;
  padding-left: 24rpx;
  border-radius: 8rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(16, 30, 54, 0.08);
  display: flex;
  align-items: center;
}

.search-row input {
  flex: 1;
  height: 76rpx;
  font-size: 27rpx;
}

.search-row button {
  width: 116rpx;
  height: 76rpx;
  color: #fb8c00;
  font-size: 27rpx;
  font-weight: 700;
}

.filter-scroll {
  width: 100%;
  margin-top: 24rpx;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  height: 58rpx;
  min-width: 112rpx;
  margin-right: 14rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  background: #fff;
  color: #687386;
  font-size: 26rpx;
  align-items: center;
  justify-content: center;
}

.filter-chip.active {
  background: #172033;
  color: #fff;
}

.room-card {
  overflow: hidden;
  margin-bottom: 22rpx;
}

.room-image {
  width: 100%;
  height: 330rpx;
  display: block;
}

.room-body {
  padding: 22rpx;
}

.room-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.room-title {
  font-size: 32rpx;
  font-weight: 800;
}

.room-address {
  margin-top: 14rpx;
  color: #687386;
  font-size: 24rpx;
  line-height: 1.4;
}

.room-meta {
  margin-top: 12rpx;
  color: #172033;
  font-size: 25rpx;
}

.room-foot {
  margin-top: 18rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.rent {
  color: #e53935;
  font-size: 40rpx;
  font-weight: 800;
}

.rent-unit {
  color: #e53935;
  font-size: 24rpx;
}

.profit {
  color: #18a058;
  font-size: 25rpx;
  font-weight: 700;
}
