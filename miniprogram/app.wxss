page {
  background: #fffaf4;
  color: #2f241d;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
}

.container {
  padding: 40rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border: 1rpx solid rgba(82, 54, 31, 0.08);
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 12rpx 36rpx rgba(78, 47, 21, 0.07);
  box-sizing: border-box;
}

.primary-btn {
  width: 100%;
  height: 92rpx;
  color: #ffffff;
  background: #ff8a3d;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
}

.primary-btn::after {
  border: 0;
}

.primary-btn[disabled] {
  color: rgba(255, 255, 255, 0.85);
  background: #f0b080;
}

.muted {
  color: #8a7867;
  font-size: 24rpx;
}
