page {
  min-height: 100%;
  background: #f5f6f8;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  border: 0;
  border-radius: 0;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
}

.safe-bottom {
  height: 48rpx;
}

.section-title {
  margin: 28rpx 0 18rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #172033;
}

.muted {
  color: #7d8798;
}

.primary-btn {
  height: 88rpx;
  border-radius: 8rpx;
  background: #fb8c00;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ghost-btn {
  height: 72rpx;
  border-radius: 8rpx;
  border: 2rpx solid #e3e7ee;
  color: #172033;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card {
  background: #fff;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 30, 54, 0.06);
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  color: #ffffff;
  background: #18a058;
}

.tag.orange {
  background: #fb8c00;
}

.tag.gray {
  background: #8a94a6;
}

.empty {
  padding: 80rpx 24rpx;
  color: #8a94a6;
  text-align: center;
  font-size: 28rpx;
}
