PORT=3000
NODE_ENV=development
CORS_ORIGIN=*
PUBLIC_BASE_URL=

# OpenAI-compatible image relay. Example:
# IMAGE_RELAY_BASE_URL=https://your-relay.example.com/v1
# IMAGE_RELAY_API_KEY=sk-xxxx
# IMAGE_RELAY_MODEL=gpt-image-2
IMAGE_RELAY_BASE_URL=https://api.openai.com/v1
IMAGE_RELAY_API_KEY=
IMAGE_RELAY_EDIT_PATH=/images/edits
IMAGE_RELAY_MODEL=gpt-image-2
IMAGE_RELAY_SIZE=1024x1024
IMAGE_RELAY_OUTPUT_FORMAT=png
IMAGE_RELAY_QUALITY=
IMAGE_RELAY_BACKGROUND=auto
IMAGE_RELAY_N=1
IMAGE_RELAY_MAX_INPUT_MB=20
